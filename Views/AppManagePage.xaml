<UserControl x:Class="QuestADBTool.Views.AppManagePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock Text="应用管理" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock x:Name="AppCountText" DockPanel.Dock="Right" Foreground="{DynamicResource TextDim}" Margin="10,0,0,0" Text="应用数：0"/>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0">
                            <Button x:Name="AppRefreshButton" Content="刷新列表" Height="36" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,8"/>
                            <CheckBox x:Name="AppIncludeSystemCheckBox" Content="包含系统/预装应用" VerticalAlignment="Center" Margin="0,6,0,0"/>
                        </WrapPanel>

                        <TextBox x:Name="AppSearchBox" Grid.Row="1" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8" ToolTip="按名称或包名搜索"/>

                        <StackPanel Grid.Row="2" Margin="0,0,0,8" Visibility="Collapsed" x:Name="AppRefreshProgressPanel">
                            <DockPanel LastChildFill="True">
                                <TextBlock x:Name="AppRefreshProgressText" Foreground="{DynamicResource TextDim}" Text="正在读取..." />
                                <TextBlock x:Name="AppRefreshProgressValueText" DockPanel.Dock="Right" Foreground="{DynamicResource TextDim}" Margin="8,0,0,0" Text="0%"/>
                            </DockPanel>
                            <ProgressBar x:Name="AppRefreshProgressBar" Height="6" Margin="0,6,0,0" Minimum="0" Maximum="100" Value="0"/>
                        </StackPanel>

                        <ListBox x:Name="AppListBox" Grid.Row="3" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" LastChildFill="True">
                                            <Border x:Name="OfficialBadge"
                                                    DockPanel.Dock="Right"
                                                    Visibility="Collapsed"
                                                    Margin="8,0,0,0"
                                                    Padding="6,1"
                                                    CornerRadius="6"
                                                    Background="#E7F6EC"
                                                    BorderBrush="#8FD4A8"
                                                    BorderThickness="1">
                                                <TextBlock Text="官方" FontSize="11" FontWeight="SemiBold" Foreground="#1F7A47"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <TextBlock Grid.Row="1" Text="{Binding PackageName}" Foreground="{DynamicResource TextDim}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsOfficialApp}" Value="True">
                                            <Setter TargetName="OfficialBadge" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="当前选中" FontWeight="SemiBold"/>
                        <TextBlock x:Name="AppSelectedPackageText" Margin="0,8,0,0" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap" Text="包名：-"/>

                        <WrapPanel Margin="0,12,0,0">
                            <Button x:Name="AppLaunchButton" Height="36" Content="启动应用" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,8"/>
                            <Button x:Name="AppForceStopButton" Height="36" Content="强制停止" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="AppUninstallButton" Height="36" Content="卸载应用" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="AppClearDataButton" Height="36" Content="清除数据" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="AppExportApkButton" Height="36" Content="导出APK" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="AppOpenSettingsButton" Height="36" Content="应用详情" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="AppReadPermissionsButton" Height="36" Content="查看权限" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="AppCopyPackageButton" Height="36" Content="复制包名" Style="{DynamicResource FluentButton}" Margin="0,0,0,8"/>
                        </WrapPanel>

                        <Border Margin="0,8,0,0" Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                            <TextBlock Foreground="{DynamicResource TextDim}" TextWrapping="Wrap" Text="提示：卸载前建议确认应用来源。系统应用通常不可直接卸载；可勾选“包含系统应用”仅用于查看。"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>