<UserControl x:Class="QuestADBTool.Views.InstallPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border x:Name="InstallCardBorder" Style="{StaticResource CardBorder}" AllowDrop="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="InstallLeftColumn" Width="1.35*"/>
                <ColumnDefinition x:Name="InstallRightColumn" Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Row="0" Grid.ColumnSpan="2" LastChildFill="False">
                <TextBlock Text="安装应用到 Quest" FontSize="14" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6" Padding="10,3" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="InstallDeviceStateDot" Width="8" Height="8" Fill="{DynamicResource TextDim}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="InstallDeviceStateText" Text="连接未知" Foreground="{DynamicResource TextDim}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="InstallHeaderRefreshButton"
                            Margin="8,0,0,0"
                            Padding="10,3"
                            MinWidth="0"
                            MinHeight="0"
                            Background="{DynamicResource SurfaceSubtle}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1"
                            Foreground="{DynamicResource Text}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="重新检测" FontSize="12" FontWeight="SemiBold"/>
                    </Button>
                    <Border Background="{DynamicResource SuccessBg}" BorderBrush="{DynamicResource SuccessBorder}" BorderThickness="1" CornerRadius="6" Padding="10,3" Margin="8,0,0,0">
                        <TextBlock x:Name="InstallSuccessBadge" Text="成功 0" Foreground="{DynamicResource SuccessText}" FontSize="12"/>
                    </Border>
                    <Border Background="{DynamicResource ErrorBg}" BorderBrush="{DynamicResource ErrorBorder}" BorderThickness="1" CornerRadius="6" Padding="10,3" Margin="8,0,0,0">
                        <TextBlock x:Name="InstallFailBadge" Text="失败 0" Foreground="{DynamicResource ErrorText}" FontSize="12"/>
                    </Border>
                </StackPanel>
            </DockPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,12,0">
                <TextBlock Text="选择一个或多个 .apk 后加入队列，再开始安装" Foreground="{DynamicResource TextDim}" Margin="0,0,0,10"/>

                <Border Margin="0,0,0,10" Padding="10,8" CornerRadius="8" BorderThickness="1"
                        Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource BorderStrong}">
                    <TextBlock Text="可直接拖入多个 .apk 文件到此区域（或路径输入框）加入队列"
                               Foreground="{DynamicResource TextDim}"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ApkPathBox" Height="36" VerticalContentAlignment="Center" AllowDrop="True"/>

                    <Button x:Name="PickApkButton" Grid.Column="1" Height="36" Margin="10,0,0,0" Style="{DynamicResource FluentButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" Margin="0,0,6,0"/>
                            <TextBlock Text="选择应用"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="InstallApkButton" Grid.Column="2" Height="36" Margin="10,0,0,0" Style="{DynamicResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE898;" Margin="0,0,6,0"/>
                            <TextBlock Text="加入队列"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                        Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}">
                    <StackPanel>
                        <TextBlock Text="连接提示" FontWeight="SemiBold"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Foreground="{DynamicResource TextDim}" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="1" Text="若提示“需要授权”，请戴上头显后点击“允许 USB 调试”。" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Foreground="{DynamicResource TextDim}" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="1" Text="连接不稳定或 offline 时，优先使用主板 USB 2.0 Type-A 接口。" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Foreground="{DynamicResource TextDim}" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="1" Text="安装队列支持失败项重试，可先批量加入再统一开始安装。" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                        Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}">
                    <StackPanel>
                        <TextBlock Text="向头显输入文字" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="在头显点击输入框，弹出虚拟键盘后，再发送到 Quest 当前聚焦的输入框" Foreground="{DynamicResource TextDim}" Margin="0,6,0,10" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="InputTextBox" Height="40" Padding="12,6" VerticalContentAlignment="Center" ToolTip="空格会自动处理，直接输入即可。"/>
                            <Button x:Name="SendTextButton" Grid.Column="1" Height="36" Content="发送到头显" Margin="10,0,0,0" Style="{DynamicResource PrimaryButton}"/>
                        </Grid>

                        <TextBlock Text="示例：war thunder（空格会自动处理）。尽量避免很长或复杂符号。" Foreground="{DynamicResource TextDim}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,10,0,0">
                <Border Padding="10,8" CornerRadius="8" BorderThickness="1"
                        Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="ApkInfoFileText" Grid.Row="0" Grid.Column="0" Text="文件：-" Foreground="{DynamicResource TextDim}" Margin="0,0,10,4"/>
                        <TextBlock x:Name="ApkInfoSizeText" Grid.Row="0" Grid.Column="1" Text="大小：-" Foreground="{DynamicResource TextDim}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ApkInfoPackageText" Grid.Row="1" Grid.Column="0" Text="包名：-" Foreground="{DynamicResource TextDim}" Margin="0,0,10,4"/>
                        <TextBlock x:Name="ApkInfoVersionText" Grid.Row="1" Grid.Column="1" Text="版本：-" Foreground="{DynamicResource TextDim}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ApkInfoSdkText" Grid.Row="2" Grid.Column="0" Text="SDK：-" Foreground="{DynamicResource TextDim}" Margin="0,0,10,4"/>
                        <TextBlock x:Name="ApkInfoAbiText" Grid.Row="2" Grid.Column="1" Text="ABI：-" Foreground="{DynamicResource TextDim}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ApkInfoSignatureText" Grid.Row="3" Grid.ColumnSpan="2" Text="签名：-" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Border Margin="0,10,0,0" Padding="8,6" CornerRadius="8" BorderThickness="1"
                        Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}">
                    <Expander x:Name="AdvancedOptionsExpander" IsExpanded="False">
                        <Expander.Header>
                            <TextBlock Text="高级安装选项" FontWeight="SemiBold"/>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox x:Name="ReplaceInstallCheckBox" IsChecked="True" Content="覆盖安装 (-r)" Margin="0,0,0,8"
                                      ToolTip="保留应用数据并覆盖安装同包名应用。"/>
                            <CheckBox x:Name="AllowDowngradeCheckBox" Content="允许降级 (-d)" Margin="0,0,0,8"
                                      ToolTip="安装更低版本时需要勾选；通常用于回退版本。"/>
                            <CheckBox x:Name="AllowTestApkCheckBox" Content="允许测试包 (-t)"
                                      ToolTip="安装 testOnly APK 时需要勾选。"/>
                            <TextBlock Text="说明：覆盖安装会保留应用数据；降级用于装低版本；测试包用于 testOnly APK。"
                                       Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Expander>
                </Border>

                <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                        Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="安装队列" FontWeight="SemiBold"/>
                            <TextBlock x:Name="QueueCountText" DockPanel.Dock="Right" Text="待处理：0" Foreground="{DynamicResource TextDim}"/>
                        </DockPanel>

                        <ListBox x:Name="QueueListBox" Height="116" Margin="0,8,0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="{Binding FileName, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                        <Border Grid.Row="0" Grid.Column="1" Padding="8,2" CornerRadius="6"
                                                Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1">
                                            <TextBlock Text="{Binding StatusDisplay, Mode=OneWay}" Foreground="{DynamicResource TextDim}" FontSize="12"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,3,0,0" FontSize="12" Foreground="{DynamicResource TextDim}">
                                            <Run Text="尝试 "/><Run Text="{Binding AttemptCount, Mode=OneWay}"/>
                                            <Run Text=" 次  "/>
                                            <Run Text="最近耗时 "/><Run Text="{Binding LastElapsedDisplay, Mode=OneWay}"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,2,0,0" FontSize="12" Foreground="{DynamicResource TextDim}" TextTrimming="CharacterEllipsis">
                                            <Run Text="原因："/><Run Text="{Binding LastReasonShort, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <WrapPanel>
                            <Button x:Name="AddQueueButton" Height="36" Content="添加文件" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="StartQueueButton" Height="36" Content="开始安装" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,8"/>
                            <Button x:Name="PauseQueueButton" Height="36" Content="暂停后续" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="StopQueueButton" Height="36" Content="停止队列" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="ClearQueueButton" Height="36" Content="清空队列" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="RetryFailedButton" Height="36" Content="重试失败项" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="ExportQueueResultButton" Height="36" Content="导出结果" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                            <Button x:Name="RemoveSelectedButton" Height="36" Content="移除选中" Style="{DynamicResource FluentButton}" IsEnabled="False" Margin="0,0,0,8"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:Name="InstallBusyOverlay" Grid.RowSpan="2" Grid.ColumnSpan="2" Visibility="Collapsed" Background="{DynamicResource SurfaceOverlay}">
                <Border Width="300" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{DynamicResource Card}" BorderBrush="{DynamicResource BorderStrong}" BorderThickness="1" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock x:Name="InstallOverlayText" Text="正在处理安装队列..." FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="InstallOverlayProgressBar" Height="8" Margin="0,10,0,0" IsIndeterminate="True"/>
                        <TextBlock x:Name="InstallOverlayElapsedText" Text="已耗时 00:00" Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>