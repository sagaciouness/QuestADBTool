<UserControl x:Class="QuestADBTool.Views.DevicePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.75*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="{DynamicResource TextDim}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="设备连接" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusText" Text="正在检测..." Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" FontSize="14"/>
                        <TextBlock x:Name="StatusHintText" Text="请保持头显已开机并连接数据线" Foreground="{DynamicResource TextDim}" Opacity="0.82" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0">
                        <Button x:Name="RefreshButton" Content="重新检测" Height="44" Margin="0,0,8,8" Style="{DynamicResource PrimaryButton}"/>
                        <Button x:Name="RestartButton" Content="修复连接" Height="44" Margin="0,0,8,8" Style="{DynamicResource FluentButton}"/>
                        <Button x:Name="CheckUpdateButton" Content="检查更新" Height="44" Margin="0,0,8,8" Style="{DynamicResource FluentButton}"/>
                        <Button x:Name="GuideButton" Content="新手引导" Height="44" Margin="0,0,8,8" ToolTip="打开新手使用说明（可随时查看）" Style="{DynamicResource FluentButton}"/>
                        <Button x:Name="OpenLogButton" Content="打开问题日志" Height="44" Margin="0,0,0,8" Style="{DynamicResource FluentButton}"/>
                    </WrapPanel>

                    <Border Grid.Row="1" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10,8">
                        <TextBlock Foreground="{DynamicResource TextDim}" TextWrapping="Wrap" Text="提示：首次连接若提示需要授权，请先戴上头显点击“允许 USB 调试”；如遇 offline，优先主板 USB 2.0 Type-A 接口。"/>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Button x:Name="DeviceInfoScrollLeftButton" Visibility="Collapsed" Width="1" Height="1" MinWidth="1" MinHeight="1"/>
                <Button x:Name="DeviceInfoScrollRightButton" Visibility="Collapsed" Width="1" Height="1" MinWidth="1" MinHeight="1"/>

                <ScrollViewer x:Name="DeviceInfoScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" CanContentScroll="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <TextBlock x:Name="DeviceSerialText" Text="设备序列号：-" Foreground="{DynamicResource TextDim}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Margin="0,0,10,10" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <TextBlock x:Name="DeviceModelText" Text="设备型号：-" Foreground="{DynamicResource TextDim}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" Margin="0,0,0,10" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <TextBlock x:Name="DeviceAndroidText" Text="Android：-" Foreground="{DynamicResource TextDim}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <TextBlock x:Name="DeviceBatteryText" Text="电量：-" Foreground="{DynamicResource TextDim}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Margin="0,0,10,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <TextBlock x:Name="DeviceStorageText" Text="存储：-" Foreground="{DynamicResource TextDim}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Margin="0,0,0,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <TextBlock Foreground="{DynamicResource TextDim}" Text="连接方式：USB 调试"/>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="屏幕工具" FontWeight="SemiBold"/>
                        <TextBlock Text="截图会保存到“图片\\QuestADBTool”，录屏会保存到“视频\\QuestADBTool”。" Margin="0,6,0,0" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
                        <WrapPanel Margin="0,8,0,0">
                            <Button x:Name="ExpCaptureScreenButton" Height="34" Content="截图并保存" Style="{DynamicResource PrimaryButton}"/>
                            <Button x:Name="ExpStartRecordButton" Height="34" Margin="8,0,0,0" Content="开始录屏" Style="{DynamicResource FluentButton}"/>
                            <Button x:Name="ExpStopRecordButton" Height="34" Margin="8,0,0,0" Content="停止并保存" Style="{DynamicResource FluentButton}"/>
                        </WrapPanel>
                        <TextBlock x:Name="ExpRecordStateText" Margin="0,8,0,0" Foreground="{DynamicResource TextDim}" Text="录屏状态：未开始"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="用户自定义脚本（逐行执行）" FontWeight="SemiBold"/>
                            <TextBlock Text="每行一条命令；默认按 shell 子命令执行。以 # 开头的行会被忽略。你可以按自己的流程自由编辑。" Margin="0,6,0,0" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
                            <TextBox x:Name="ExpAutomationScriptBox"
                                     Margin="0,8,0,0"
                                     Height="96"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     ToolTip="示例：getprop ro.product.model"/>
                            <WrapPanel Margin="0,8,0,0">
                                <Button x:Name="ExpRunAutomationButton" Height="34" Content="执行脚本" Style="{DynamicResource PrimaryButton}"/>
                                <Button x:Name="ExpFillAutomationTemplateButton" Height="34" Margin="8,0,0,0" Content="填充通用模板" Style="{DynamicResource FluentButton}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>


