<UserControl x:Class="QuestADBTool.Views.LogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border Style="{StaticResource CardBorder}">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" LastChildFill="True">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="日志" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="   出现问题时，请点击“打开问题日志”并发送最新日志给作者。" Foreground="{StaticResource TextDim}" Margin="10,2,0,0"/>
                </StackPanel>
                <Button x:Name="ToggleLogButton" DockPanel.Dock="Right" Height="32" Content="展开日志" Style="{DynamicResource FluentButton}"/>
            </DockPanel>

            <Border DockPanel.Dock="Top" Margin="0,10,0,0" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="历史操作记录" FontWeight="SemiBold"/>
                        <Button x:Name="CopyHistoryButton" DockPanel.Dock="Right" Height="30" Content="复制记录" Style="{DynamicResource FluentButton}" Margin="8,0,0,0"/>
                        <Button x:Name="ClearHistoryButton" DockPanel.Dock="Right" Height="30" Content="清空记录" Style="{DynamicResource FluentButton}"/>
                    </DockPanel>
                    <ListBox x:Name="OperationHistoryListBox" Height="180" Margin="0,8,0,0" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Foreground="{StaticResource TextDim}" Text="{Binding TimeText}"/>
                                    <TextBlock Grid.Column="2" TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Category}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Action}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Target}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Result}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <StackPanel x:Name="LogBodyPanel" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,10">
                    <Button x:Name="AuthorButton" Content="跳转作者" Height="36" Padding="12,6" Style="{DynamicResource FluentButton}" />
                    <Button x:Name="ClearLogButton" Content="清空" Height="36" Padding="12,6" Margin="8,0,0,0" Style="{DynamicResource FluentButton}" />
                    <Button x:Name="CopyLogButton" Content="复制全部" Height="36" Padding="12,6" Margin="8,0,0,0" Style="{DynamicResource FluentButton}" />
                </StackPanel>

                <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True" VerticalAlignment="Stretch" MinHeight="100" MaxHeight="180" FontFamily="Consolas"/>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
