<Window x:Class="QuestADBTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quest 安装与输入工具" Height="600" Width="980"
        WindowStartupLocation="CenterScreen"
        SizeChanged="Window_SizeChanged"
        Background="{DynamicResource Bg}" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Grid x:Name="RootLayoutGrid" UseLayoutRounding="True" SnapsToDevicePixels="True" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <Border Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#9CA3AF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="设备连接" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock x:Name="StatusText" Text="正在检测..." Foreground="{StaticResource TextDim}" Margin="0,6,0,0"/>
                            <TextBlock x:Name="StatusHintText" Text="请保持头显已开机并连接数据线" Foreground="{StaticResource TextDim}" Opacity="0.78" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Margin="10,0,0,0" Padding="6" CornerRadius="8" BorderThickness="1" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="重新检测" Height="36" Margin="0,0,8,0" Click="Refresh_Click" Style="{DynamicResource FluentButton}" x:Name="RefreshButton" />
                                <Button Content="修复连接" Height="36" Click="RestartAdb_Click" Style="{DynamicResource FluentButton}" x:Name="RestartButton" />
                            </StackPanel>
                        </Border>
                        <Border Margin="10,0,0,0" Padding="6" CornerRadius="8" BorderThickness="1" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="新手引导" Height="36" Margin="0,0,8,0" Click="Guide_Click" ToolTip="打开新手使用说明（可随时查看）" Style="{DynamicResource FluentButton}" x:Name="GuideButton" />
                                <Button Content="打开问题日志" Height="36" Click="OpenLog_Click" Style="{DynamicResource FluentButton}" x:Name="OpenLogButton" />
                                <Button Content="检查更新" Height="36" Margin="8,0,0,0" Click="CheckUpdate_Click" Style="{DynamicResource FluentButton}" x:Name="CheckUpdateButton" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="DeviceInfoScrollLeftButton"
                            Width="28"
                            Height="28"
                            MinWidth="28"
                            MinHeight="28"
                            Margin="0,3,8,0"
                            Content="&#xE76B;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="DeviceInfoScrollLeft_Click"
                            Style="{DynamicResource FluentButton}"/>

                    <ScrollViewer Grid.Column="1"
                                  x:Name="DeviceInfoScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <StackPanel Orientation="Horizontal">
                            <Border Margin="0,0,8,0" MinWidth="170" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                                <TextBlock x:Name="DeviceSerialText" Text="设备序列号：-" Foreground="{StaticResource TextDim}" TextWrapping="NoWrap"/>
                            </Border>
                            <Border Margin="0,0,8,0" MinWidth="170" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                                <TextBlock x:Name="DeviceModelText" Text="设备型号：-" Foreground="{StaticResource TextDim}" TextWrapping="NoWrap"/>
                            </Border>
                            <Border Margin="0,0,8,0" MinWidth="170" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                                <TextBlock x:Name="DeviceAndroidText" Text="Android：-" Foreground="{StaticResource TextDim}" TextWrapping="NoWrap"/>
                            </Border>
                            <Border Margin="0,0,8,0" MinWidth="170" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                                <TextBlock x:Name="DeviceBatteryText" Text="电量：-" Foreground="{StaticResource TextDim}" TextWrapping="NoWrap"/>
                            </Border>
                            <Border Margin="0,0,8,0" MinWidth="170" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                                <TextBlock x:Name="DeviceStorageText" Text="存储：-" Foreground="{StaticResource TextDim}" TextWrapping="NoWrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Column="2"
                            x:Name="DeviceInfoScrollRightButton"
                            Width="28"
                            Height="28"
                            MinWidth="28"
                            MinHeight="28"
                            Margin="8,3,0,0"
                            Content="&#xE76C;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="DeviceInfoScrollRight_Click"
                            Style="{DynamicResource FluentButton}"/>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="NoticeBar" Grid.Row="1" Margin="0,10,0,0" Background="{StaticResource InfoBg}" BorderBrush="{StaticResource InfoBorder}" BorderThickness="1" CornerRadius="10" Padding="10,8" Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="NoticeTagText" Text="提示" FontWeight="SemiBold" Foreground="{StaticResource InfoText}" Margin="0,0,8,0"/>
                <Button x:Name="NoticeCloseButton" DockPanel.Dock="Right" Width="28" Height="28" Click="NoticeClose_Click" Style="{DynamicResource FluentButton}" Content="×" Padding="0"/>
                <TextBlock x:Name="NoticeText" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <TextBlock x:Name="BusyText" Grid.Row="1" Text="" Foreground="{DynamicResource TextDim}"
                   HorizontalAlignment="Right" Margin="0,12,0,0" Visibility="Collapsed"/>

        <Border x:Name="UpdatePanel" Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12" Margin="0,8,0,0" Visibility="Collapsed">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock Text="发现新版本" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="UpdateVersionText" DockPanel.Dock="Right" Foreground="{StaticResource TextDim}" Margin="10,0,0,0" Text="v-"/>
                </DockPanel>
                <TextBlock x:Name="UpdatePublishedText" Margin="0,4,0,0" Foreground="{StaticResource TextDim}" Text="发布时间：-"/>
                <Border Margin="0,6,0,0" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                    <TextBlock x:Name="UpdateNotesText" MaxHeight="56" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Text="更新内容：-"/>
                </Border>
                <WrapPanel Margin="0,8,0,0">
                    <Button x:Name="UpdateGithubButton" Height="36" Content="GitHub 下载" Click="UpdateGithub_Click" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button x:Name="UpdateBaiduButton" Height="36" Content="百度网盘下载" Click="UpdateBaidu_Click" Style="{DynamicResource FluentButton}" Margin="0,0,8,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border x:Name="InstallCardBorder" Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,14,0,0"
                AllowDrop="True"
                PreviewDragOver="InstallArea_PreviewDragOver"
                DragLeave="InstallArea_DragLeave"
                Drop="InstallArea_Drop">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="InstallLeftColumn" Width="1.35*"/>
                    <ColumnDefinition x:Name="InstallRightColumn" Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Row="0" Grid.ColumnSpan="2" LastChildFill="False">
                    <TextBlock Text="安装应用到 Quest" FontSize="14" FontWeight="SemiBold"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="{StaticResource SuccessBg}" BorderBrush="{StaticResource SuccessBorder}" BorderThickness="1" CornerRadius="6" Padding="10,3" Margin="8,0,0,0">
                            <TextBlock x:Name="InstallSuccessBadge" Text="成功 0" Foreground="{StaticResource SuccessText}" FontSize="12"/>
                        </Border>
                        <Border Background="{StaticResource ErrorBg}" BorderBrush="{StaticResource ErrorBorder}" BorderThickness="1" CornerRadius="6" Padding="10,3" Margin="8,0,0,0">
                            <TextBlock x:Name="InstallFailBadge" Text="失败 0" Foreground="{StaticResource ErrorText}" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,12,0">
                    <TextBlock Text="选择一个或多个 .apk 后加入队列，再开始安装" Foreground="{StaticResource TextDim}" Margin="0,0,0,10"/>

                    <Border Margin="0,0,0,10" Padding="10,8" CornerRadius="8" BorderThickness="1"
                            Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource BorderStrong}">
                        <TextBlock Text="可直接拖入多个 .apk 文件到此区域（或路径输入框）加入队列"
                                   Foreground="{DynamicResource TextDim}"/>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="ApkPathBox" Height="36" VerticalContentAlignment="Center"
                                 TextChanged="ApkPathBox_TextChanged"
                                 AllowDrop="True"
                                 PreviewDragOver="InstallArea_PreviewDragOver"
                                 DragLeave="InstallArea_DragLeave"
                                 Drop="InstallArea_Drop"/>

                        <Button Grid.Column="1" Height="36" Margin="10,0,0,0" Click="PickApk_Click" Style="{DynamicResource FluentButton}" x:Name="PickApkButton">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" Margin="0,0,6,0"/>
                                <TextBlock Text="选择..."/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="InstallApkButton" Grid.Column="2" Height="36" Margin="10,0,0,0" Click="InstallApk_Click" Style="{DynamicResource PrimaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE898;" Margin="0,0,6,0"/>
                                <TextBlock Text="加入队列"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                            Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}">
                        <StackPanel>
                            <TextBlock Text="连接提示" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="•" Foreground="{StaticResource TextDim}" Margin="0,0,6,0"/>
                                <TextBlock Text="若提示“需要授权”，请戴上头显后点击“允许 USB 调试”。" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="•" Foreground="{StaticResource TextDim}" Margin="0,0,6,0"/>
                                <TextBlock Text="连接不稳定或 offline 时，优先使用主板 USB 2.0 Type-A 接口。" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="•" Foreground="{StaticResource TextDim}" Margin="0,0,6,0"/>
                                <TextBlock Text="安装队列支持失败项重试，可先批量加入再统一开始安装。" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                            Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}">
                        <StackPanel>
                            <TextBlock Text="向头显输入文字" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="发送到 Quest 当前聚焦的输入框" Foreground="{StaticResource TextDim}" Margin="0,6,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="InputTextBox" Height="36" VerticalContentAlignment="Center" ToolTip="空格会自动处理，直接输入即可。"/>
                                <Button x:Name="SendTextButton" Grid.Column="1" Height="36" Content="发送到头显" Margin="10,0,0,0" Click="SendText_Click" Style="{DynamicResource PrimaryButton}"/>
                            </Grid>

                            <TextBlock Text="示例：war thunder（空格会自动处理）。尽量避免很长或复杂符号。" Foreground="{StaticResource TextDim}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,10,0,0">
                    <Border Padding="10,8" CornerRadius="8" BorderThickness="1"
                            Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="ApkInfoFileText" Grid.Row="0" Grid.Column="0" Text="文件：-" Foreground="{StaticResource TextDim}" Margin="0,0,10,4"/>
                            <TextBlock x:Name="ApkInfoSizeText" Grid.Row="0" Grid.Column="1" Text="大小：-" Foreground="{StaticResource TextDim}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ApkInfoPackageText" Grid.Row="1" Grid.Column="0" Text="包名：-" Foreground="{StaticResource TextDim}" Margin="0,0,10,0"/>
                            <TextBlock x:Name="ApkInfoVersionText" Grid.Row="1" Grid.Column="1" Text="版本：-" Foreground="{StaticResource TextDim}"/>
                        </Grid>
                    </Border>

                    <Border Margin="0,10,0,0" Padding="8,6" CornerRadius="8" BorderThickness="1"
                            Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}">
                        <Expander x:Name="AdvancedOptionsExpander" IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="高级安装选项" FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <CheckBox x:Name="ReplaceInstallCheckBox" IsChecked="True" Content="覆盖安装 (-r)" Margin="0,0,0,8"
                                          ToolTip="保留应用数据并覆盖安装同包名应用。"/>
                                <CheckBox x:Name="AllowDowngradeCheckBox" Content="允许降级 (-d)" Margin="0,0,0,8"
                                          ToolTip="安装更低版本时需要勾选；通常用于回退版本。"/>
                                <CheckBox x:Name="AllowTestApkCheckBox" Content="允许测试包 (-t)"
                                          ToolTip="安装 testOnly APK 时需要勾选。"/>
                                <TextBlock Text="说明：覆盖安装会保留应用数据；降级用于装低版本；测试包用于 testOnly APK。"
                                           Foreground="{StaticResource TextDim}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                            Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="安装队列" FontWeight="SemiBold"/>
                                <TextBlock x:Name="QueueCountText" DockPanel.Dock="Right" Text="待处理：0" Foreground="{StaticResource TextDim}"/>
                            </DockPanel>

                            <ListBox x:Name="QueueListBox" Height="116" Margin="0,8,0,8" SelectionChanged="QueueListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="{Binding FileName, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                            <Border Grid.Row="0" Grid.Column="1" Padding="8,2" CornerRadius="6"
                                                    Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                                <TextBlock Text="{Binding StatusDisplay, Mode=OneWay}" Foreground="{StaticResource TextDim}" FontSize="12"/>
                                            </Border>

                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,3,0,0" FontSize="12" Foreground="{StaticResource TextDim}">
                                                <Run Text="尝试 "/><Run Text="{Binding AttemptCount, Mode=OneWay}"/>
                                                <Run Text=" 次  "/>
                                                <Run Text="最近耗时 "/><Run Text="{Binding LastElapsedDisplay, Mode=OneWay}"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,2,0,0" FontSize="12" Foreground="{StaticResource TextDim}" TextTrimming="CharacterEllipsis">
                                                <Run Text="原因："/><Run Text="{Binding LastReasonShort, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <WrapPanel>
                                <Button x:Name="AddQueueButton" Height="36" Content="添加文件" Click="AddQueueButton_Click" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                                <Button x:Name="StartQueueButton" Height="36" Content="开始安装" Click="StartQueueButton_Click" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,8"/>
                                <Button x:Name="ClearQueueButton" Height="36" Content="清空队列" Click="ClearQueueButton_Click" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                                <Button x:Name="RetryFailedButton" Height="36" Content="重试失败项" Click="RetryFailedButton_Click" Style="{DynamicResource FluentButton}" Margin="0,0,8,8"/>
                                <Button x:Name="RemoveSelectedButton" Height="36" Content="移除选中" Click="RemoveSelectedButton_Click" Style="{DynamicResource FluentButton}" IsEnabled="False" Margin="0,0,0,8"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border x:Name="InstallBusyOverlay" Grid.RowSpan="2" Grid.ColumnSpan="2" Visibility="Collapsed" Background="{StaticResource SurfaceOverlay}">
                    <Border Width="300" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="{StaticResource Card}" BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" CornerRadius="12" Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="InstallOverlayText" Text="正在处理安装队列..." FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <ProgressBar x:Name="InstallOverlayProgressBar" Height="8" Margin="0,10,0,0" IsIndeterminate="True"/>
                            <TextBlock x:Name="InstallOverlayElapsedText" Text="已耗时 00:00" Foreground="{StaticResource TextDim}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Margin="0,14,0,0">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" LastChildFill="True">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="日志" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="   出现问题时，请点击“打开问题日志”并发送最新日志给作者。" Foreground="{StaticResource TextDim}" Margin="10,2,0,0"/>
                    </StackPanel>
                    <Button x:Name="ToggleLogButton" DockPanel.Dock="Right" Height="32" Content="展开日志" Click="ToggleLogCollapse_Click" Style="{DynamicResource FluentButton}"/>
                </DockPanel>

                <StackPanel x:Name="LogBodyPanel" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,10">
                        <Button Content="跳转作者" Height="36" Padding="12,6" Click="OpenAuthor_Click" Style="{DynamicResource FluentButton}" x:Name="AuthorButton" />
                        <Button Content="清空" Height="36" Padding="12,6" Margin="8,0,0,0" Click="ClearLog_Click" Style="{DynamicResource FluentButton}" x:Name="ClearLogButton" />
                        <Button Content="复制全部" Height="36" Padding="12,6" Margin="8,0,0,0" Click="CopyLog_Click" Style="{DynamicResource FluentButton}" x:Name="CopyLogButton" />
                    </StackPanel>

                    <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True" VerticalAlignment="Stretch" MinHeight="100" MaxHeight="180" FontFamily="Consolas"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="GuideDrawer"
                Grid.RowSpan="5"
                Panel.ZIndex="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="360"
                Visibility="Collapsed"
                Background="{StaticResource Card}"
                BorderBrush="{StaticResource BorderStrong}"
                BorderThickness="1"
                CornerRadius="14"
                Margin="0,0,0,0"
                Padding="14">
            <Border.RenderTransform>
                <TranslateTransform x:Name="GuideDrawerTranslate" X="380"/>
            </Border.RenderTransform>
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                    <TextBlock Text="新手引导" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right"
                            Width="32"
                            Height="32"
                            Margin="8,0,0,0"
                            Content="×"
                            Click="GuideDrawerClose_Click"
                            Style="{DynamicResource FluentButton}"
                            Padding="0"/>
                </DockPanel>

                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="快速上手" FontWeight="SemiBold"/>
                    <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Text="1. 用可传输数据的数据线连接 Quest，并确保头显已开机。"/>
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Text="2. 戴上头显，在授权弹窗里允许 USB 调试（建议勾选始终允许）。"/>
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Text="3. 回到工具，看到“已连接”后先加入 APK 队列，再点击开始安装。"/>

                    <Border Margin="0,12,0,0" Background="{StaticResource SurfaceSubtle}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="常见问题" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Text="• 显示“需要授权”：请在头显里确认 USB 调试。"/>
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Text="• 频繁 offline：优先使用主板 USB 2.0 Type-A 接口。"/>
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Text="• 安装失败：在队列项中查看失败原因并按建议重试。"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
