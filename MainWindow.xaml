<Window x:Class="QuestADBTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:QuestADBTool.Views"
        Title="Quest 安装与输入工具" Height="600" Width="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SizeChanged="Window_SizeChanged"
        Background="{DynamicResource Bg}" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="NavRailBgBrush" Color="#ECECED"/>
        <SolidColorBrush x:Key="NavRailBorderBrush" Color="#DFDFE2"/>
        <SolidColorBrush x:Key="NavItemHoverBrush" Color="#E1E1E4"/>
        <SolidColorBrush x:Key="NavItemActiveBrush" Color="#D8D8DC"/>
        <SolidColorBrush x:Key="NavIconIdleBrush" Color="#C5C5C9"/>
        <SolidColorBrush x:Key="NavIconActiveBrush" Color="#1C1C1F"/>
        <SolidColorBrush x:Key="NavTextIdleBrush" Color="#8A8A90"/>
        <SolidColorBrush x:Key="NavTextActiveBrush" Color="#1F1F23"/>

        <Style x:Key="NavRailItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavItemActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceSubtle}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBarBorder" Grid.Row="0" Background="#F3F4F6" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinButton" Style="{StaticResource TitleButtonStyle}" Click="MinButton_Click" Content="&#xE921;"/>
                    <Button x:Name="MaxRestoreButton" Style="{StaticResource TitleButtonStyle}" Click="MaxRestoreButton_Click" Content="&#xE922;"/>
                    <Button x:Name="CloseButton" Width="46" Height="36" Click="CloseButton_Click" BorderThickness="0" Cursor="Hand" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource TextDim}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C50F1F"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="RootLayoutGrid" Grid.Row="1" UseLayoutRounding="True" SnapsToDevicePixels="True" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="NavRail" Grid.Column="0" Width="56" Background="{DynamicResource NavRailBgBrush}" BorderBrush="{DynamicResource NavRailBorderBrush}" BorderThickness="1" CornerRadius="0" Padding="0" MouseEnter="NavRail_MouseEnter" MouseLeave="NavRail_MouseLeave">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Height="82" Margin="0,14,0,0">
                        <Border x:Name="NavBrandIconHost" Width="30" Height="30" VerticalAlignment="Top" HorizontalAlignment="Center" Visibility="Visible">
                            <Image x:Name="NavBrandIcon"
                                   Source="/app.ico"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True"/>
                        </Border>
                        <StackPanel VerticalAlignment="Top" Margin="0,0,0,0">
                            <TextBlock x:Name="NavBrandTextA" Text="QTool" Margin="16,0,0,0" FontSize="26" FontWeight="Black" Foreground="{DynamicResource Text}" Opacity="0" Visibility="Collapsed">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform X="8"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock x:Name="NavBrandTextB" Text="Quest ADB 工具" Margin="16,-3,0,0" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextDim}" Opacity="0" Visibility="Collapsed">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform X="8"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,-16,0,0" VerticalAlignment="Top">
                        <Button x:Name="NavDeviceButton" Height="54" Margin="0,0,0,1" Style="{StaticResource NavRailItemButtonStyle}" ToolTip="设备" Click="NavDevice_Click" HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Border x:Name="NavDeviceIndicator" Width="6" Background="#111214" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="NavDeviceIcon" Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="22" Width="26" VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource NavIconIdleBrush}"/>
                                    <TextBlock x:Name="NavDeviceText" Text="设备" Margin="20,0,0,0" FontSize="14" FontWeight="SemiBold" Opacity="0" Foreground="{DynamicResource NavTextIdleBrush}" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform X="8"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="NavInstallButton" Height="54" Margin="0,0,0,1" Style="{StaticResource NavRailItemButtonStyle}" ToolTip="安装" Click="NavInstall_Click" HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Border x:Name="NavInstallIndicator" Width="6" Background="#111214" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="NavInstallIcon" Text="&#xE7ac;" FontFamily="Segoe MDL2 Assets" FontSize="22" Width="26" VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource NavIconIdleBrush}"/>
                                    <TextBlock x:Name="NavInstallText" Text="安装" Margin="20,0,0,0" FontSize="14" FontWeight="SemiBold" Opacity="0" Foreground="{DynamicResource NavTextIdleBrush}" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform X="8"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="NavAppsButton" Height="54" Margin="0,0,0,1" Style="{StaticResource NavRailItemButtonStyle}" ToolTip="应用" Click="NavApps_Click" HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Border x:Name="NavAppsIndicator" Width="6" Background="#111214" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="NavAppsIcon" Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="22" Width="26" VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource NavIconIdleBrush}"/>
                                    <TextBlock x:Name="NavAppsText" Text="应用" Margin="20,0,0,0" FontSize="14" FontWeight="SemiBold" Opacity="0" Foreground="{DynamicResource NavTextIdleBrush}" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform X="8"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="NavLogButton" Height="54" Margin="0,0,0,1" Style="{StaticResource NavRailItemButtonStyle}" ToolTip="日志" Click="NavLog_Click" HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Border x:Name="NavLogIndicator" Width="6" Background="#111214" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="NavLogIcon" Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="22" Width="26" VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource NavIconIdleBrush}"/>
                                    <TextBlock x:Name="NavLogText" Text="日志" Margin="20,0,0,0" FontSize="14" FontWeight="SemiBold" Opacity="0" Foreground="{DynamicResource NavTextIdleBrush}" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform X="8"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="NavAboutButton" Height="54" Style="{StaticResource NavRailItemButtonStyle}" ToolTip="实验" Click="NavAbout_Click" HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Border x:Name="NavAboutIndicator" Width="6" Background="#111214" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="NavAboutIcon" Text="&#xE730;" FontFamily="Segoe MDL2 Assets" FontSize="22" Width="26" VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource NavIconIdleBrush}"/>
                                    <TextBlock x:Name="NavAboutText" Text="实验" Margin="20,0,0,0" FontSize="14" FontWeight="SemiBold" Opacity="0" Foreground="{DynamicResource NavTextIdleBrush}" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform X="8"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="2" Width="56" HorizontalAlignment="Left" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6" Padding="4" HorizontalAlignment="Center">
                            <Button x:Name="NavBilibiliButton" Width="28" Height="28" Style="{StaticResource NavRailItemButtonStyle}" ToolTip="哔哩哔哩" Click="OpenAuthor_Click">
                                <TextBlock Text="&#xE8f2;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextDim}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Border>

                        <Border Grid.Row="1" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6" Padding="4" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button x:Name="NavThemeToggleButton" Width="28" Height="28" Style="{StaticResource NavRailItemButtonStyle}" Click="NavThemeToggle_Click" ToolTip="开启黑夜模式">
                                <TextBlock x:Name="NavThemeToggleIcon" Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextDim}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Border>

                        <Button x:Name="NavPinToggleButton" Grid.Row="2" Width="28" Height="28" Margin="0,10,0,0" HorizontalAlignment="Center" Style="{StaticResource NavRailItemButtonStyle}" Click="NavPinToggle_Click" ToolTip="展开侧栏">
                            <TextBlock x:Name="NavPinToggleIcon" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextDim}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="NoticeBar" Grid.Row="0" Background="{DynamicResource InfoBg}" BorderBrush="{DynamicResource InfoBorder}" BorderThickness="1" CornerRadius="10" Padding="10,8" Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="NoticeTagText" Text="提示" FontWeight="SemiBold" Foreground="{DynamicResource InfoText}" Margin="0,0,8,0"/>
                        <Button x:Name="NoticeCloseButton" DockPanel.Dock="Right" Width="28" Height="28" Click="NoticeClose_Click" Style="{DynamicResource FluentButton}" Content="×" Padding="0"/>
                        <TextBlock x:Name="NoticeText" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </DockPanel>
                </Border>

                <TextBlock x:Name="BusyText" Grid.Row="0" Text="" Foreground="{DynamicResource TextDim}"
                           HorizontalAlignment="Right" Margin="0,12,0,0" Visibility="Collapsed"/>

                <Border x:Name="UpdatePanel" Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="0,10,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="发现新版本" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="UpdateVersionText" DockPanel.Dock="Right" Foreground="{DynamicResource TextDim}" Margin="10,0,0,0" Text="v-"/>
                        </DockPanel>
                        <TextBlock x:Name="UpdatePublishedText" Margin="0,4,0,0" Foreground="{DynamicResource TextDim}" Text="发布时间：-"/>
                        <Border Margin="0,6,0,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                            <TextBlock x:Name="UpdateNotesText" TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" Text="更新内容：-"/>
                        </Border>
                        <WrapPanel Margin="0,8,0,0">
                            <Button x:Name="UpdateGithubButton" Height="36" Content="GitHub 下载" Click="UpdateGithub_Click" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                            <Button x:Name="UpdateBaiduButton" Height="36" Content="百度网盘下载" Click="UpdateBaidu_Click" Style="{DynamicResource FluentButton}" Margin="0,0,8,0"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <views:DevicePage x:Name="DevicePageHost" Visibility="Visible"/>
                    <views:InstallPage x:Name="InstallPageHost" Visibility="Collapsed"/>
                    <views:AppManagePage x:Name="AppManagePageHost" Visibility="Collapsed"/>
                    <views:LogPage x:Name="LogPageHost" Visibility="Collapsed"/>
                    <Border x:Name="AboutPageHost" Visibility="Collapsed" Style="{StaticResource CardBorder}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="实验功能" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="实验功能（非官方） 可能被系统还原 不同版本行为不同" Margin="0,8,0,0" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>

                                <Border Margin="0,12,0,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="当前显示参数" FontWeight="SemiBold"/>
                                            <Button x:Name="ExpReadDisplayButton"
                                                    DockPanel.Dock="Right"
                                                    Height="34"
                                                    Content="读取当前参数"
                                                    Click="ExpReadDisplay_Click"
                                                    Style="{DynamicResource FluentButton}"/>
                                        </DockPanel>
                                        <TextBlock x:Name="ExpDisplayInfoText"
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource TextDim}"
                                                   TextWrapping="Wrap"
                                                   Text="分辨率：-  刷新率：-"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,10,0,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="分辨率设置（宽范围：3200~5408 高范围：1728~2912）" FontWeight="SemiBold"/>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ExpResolutionWidthBox" Height="34" VerticalContentAlignment="Center" ToolTip="宽范围：3200~5408"/>
                                            <TextBox x:Name="ExpResolutionHeightBox" Grid.Column="2" Height="34" VerticalContentAlignment="Center" ToolTip="高范围：1728~2912"/>
                                            <Button x:Name="ExpApplyResolutionButton" Grid.Column="3" Height="34" Margin="10,0,0,0" Content="应用" Click="ExpApplyResolution_Click" Style="{DynamicResource PrimaryButton}"/>
                                            <Button x:Name="ExpResetResolutionButton" Grid.Column="4" Height="34" Margin="8,0,0,0" Content="重置" Click="ExpResetResolution_Click" Style="{DynamicResource FluentButton}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,10,0,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="刷新率设置（范围：72~120）" FontWeight="SemiBold"/>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ExpRefreshRateBox" Height="34" VerticalContentAlignment="Center" ToolTip="刷新率范围：72~120"/>
                                            <Button x:Name="ExpApplyRefreshButton" Grid.Column="1" Height="34" Margin="10,0,0,0" Content="应用" Click="ExpApplyRefresh_Click" Style="{DynamicResource PrimaryButton}"/>
                                            <Button x:Name="ExpRefresh90Button" Grid.Column="2" Height="34" Margin="8,0,0,0" Content="90Hz" Click="ExpRefresh90_Click" Style="{DynamicResource FluentButton}"/>
                                            <Button x:Name="ExpRefresh120Button" Grid.Column="3" Height="34" Margin="8,0,0,0" Content="120Hz" Click="ExpRefresh120_Click" Style="{DynamicResource FluentButton}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Border x:Name="GuideDrawer"
                    Grid.ColumnSpan="3"
                    Panel.ZIndex="10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="360"
                    Visibility="Collapsed"
                    Background="{DynamicResource Card}"
                    BorderBrush="{DynamicResource BorderStrong}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Margin="0,0,0,0"
                    Padding="14">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="GuideDrawerTranslate" X="380"/>
                </Border.RenderTransform>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                        <TextBlock Text="新手引导" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right"
                                Width="32"
                                Height="32"
                                Margin="8,0,0,0"
                                Content="×"
                                Click="GuideDrawerClose_Click"
                                Style="{DynamicResource FluentButton}"
                                Padding="0"/>
                    </DockPanel>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="快速上手" FontWeight="SemiBold"/>
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" Text="1. 用可传输数据的数据线连接 Quest，并确保头显已开机。"/>
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" Text="2. 戴上头显，在授权弹窗里允许 USB 调试（建议勾选始终允许）。"/>
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" Text="3. 工具默认会先打开“设备”页；确认状态为“已连接”后，切到“安装”页加入 APK 队列并开始安装。"/>

                        <Border Margin="0,12,0,0" Background="{DynamicResource SurfaceSubtle}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <TextBlock Text="常见问题" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" Text="• 显示“需要授权”：请在头显里确认 USB 调试。"/>
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" Text="• 频繁 offline：优先使用主板 USB 2.0 Type-A 接口。"/>
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" Text="• 安装失败：在队列项中查看失败原因并按建议重试。"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <Border x:Name="LaunchOverlay"
                Grid.RowSpan="2"
                Panel.ZIndex="200"
                Background="{DynamicResource Bg}"
                Opacity="1"
                Visibility="Visible">
            <Grid>
                <Border x:Name="LaunchCard"
                        Width="420"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Card}"
                        BorderBrush="{DynamicResource BorderStrong}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="LaunchCardScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="38" Height="38" Background="{DynamicResource SurfaceSubtle}" CornerRadius="10">
                                <Image Source="/app.ico" Stretch="Uniform" Margin="6"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Quest ADB Tool" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                                <TextBlock x:Name="LaunchStatusText" Text="正在初始化设备与页面..." Margin="0,4,0,0" Foreground="{DynamicResource TextDim}"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,16,0,0">
                            <Border Width="16"
                                    Height="16"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <RotateTransform x:Name="LaunchSpinnerRotate" Angle="0"/>
                                </Border.RenderTransform>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextDim}"
                                           Text="&#xE895;"/>
                            </Border>
                            <ProgressBar IsIndeterminate="True"
                                         Height="6"
                                         Margin="0,0,24,0"
                                         Foreground="{DynamicResource Primary}"
                                         Background="{DynamicResource Border}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="LaunchSpinnerRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360" Duration="0:0:1.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</Window>











